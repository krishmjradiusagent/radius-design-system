{
  "system": "Radius Design System",
  "version": "1.1.0",
  "philosophy": "Figma-Instance Governance: Enforce visual parity via strict prop-driven primitives. Prevent layout drift by locking shell DNA and controlling flexibility through registered slots and booleans.",
  "heritage": {
    "shell_rounding": "32px",
    "button_rounding": "16px",
    "motion_curve": [0.32, 0.72, 0, 1],
    "spacing_base": "8px",
    "optical_alignment": "center-baseline",
    "typography": {
      "labels": "font-black uppercase tracking-widest",
      "body": "font-medium text-slate-500",
      "titles": "font-bold tracking-tight text-slate-900"
    }
  },
  "registered_primitives": {
    "PopupRoot": {
      "path": "src/components/PopupRoot.tsx",
      "slots": ["headerChip", "headerAccessory", "footerAction", "footerAccessory", "children"],
      "props": {
        "widthPreset": "sm | md | lg | xl",
        "headerAlign": "start | center",
        "showClose": "boolean",
        "backdrop": "light | dim | strong",
        "title": "string",
        "subtitle": "string",
        "subtitleClamp": "number | none",
        "footerNote": "string",
        "footerNoteClamp": "number | none"
      }
    },
    "PopupLayout": {
      "path": "src/components/PopupLayout.tsx",
      "variants": ["PopupBody", "PopupSection"],
      "body_props": {
        "layout": "list | form | confirmation | banner-list",
        "gap": "number (px)",
        "align": "start | center"
      },
      "section_props": {
        "title": "string",
        "body": "ReactNode",
        "accessory": "ReactNode"
      }
    },
    "ActionChip": {
      "path": "src/components/ActionChip.tsx",
      "variants": ["icon-only", "text-only", "icon-text", "text-icon", "icon-text-icon"],
      "tones": ["neutral", "info", "warning", "success", "destructive"],
      "appearances": ["outline", "subtle", "filled"],
      "destructive_intent": {
        "loud": "Strong red semantic signaling (e.g. Purge, Delete All)",
        "quiet": "Neutral gray tone for safety-critical but non-primary deletion (e.g. Remove Accessory)"
      }
    },
    "ContextBanner": {
      "props": {
        "tone": "destructive | warning | info | success | neutral",
        "density": "comfortable | compact",
        "descriptionClamp": "number | none"
      }
    },
    "ChoiceCard": {
      "props": {
        "tone": "indigo | destructive | neutral",
        "selectionStyle": "border | glow | fill",
        "density": "comfortable | compact"
      }
    }
  },
  "patterns": {
    "delete_rule": {
      "composition": "PopupRoot + PopupBody(confirmation) + ChoiceCardGroup",
      "governance": "Primary CTA must be destructive tone. Header should include status ActionChip."
    }
  }
}
