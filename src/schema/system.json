{
  "system": "Radius Design System",
  "version": "1.2.0",
  "philosophy": "Figma-Instance Governance: Enforce visual parity via strict prop-driven primitives. PopupRoot is the sole source of truth for shell DNA, region surfaces, and footer tray behavior.",
  "heritage": {
    "shell_rounding": "32px",
    "button_rounding": "16px",
    "motion_curve": [0.32, 0.72, 0, 1],
    "spacing_base": "8px",
    "optical_alignment": "center-baseline",
    "typography": {
      "labels": "font-black uppercase tracking-widest",
      "titles": "font-black tracking-tight text-slate-900 text-[24px]",
      "subtitles": "font-medium text-slate-500 text-[14px] leading-[1.6]"
    }
  },
  "registered_primitives": {
    "PopupRoot": {
      "path": "src/components/PopupRoot.tsx",
      "regions": ["Header", "Body", "FooterTray"],
      "props": {
        "widthPreset": "sm | md | lg | xl | editorial",
        "headerSurface": "transparent | subtle | elevated",
        "footerSurface": "transparent | subtle | elevated",
        "showFooterTray": "boolean",
        "footerTrayInset": "none | soft | card-aligned",
        "showHeaderDivider": "boolean",
        "showBodyDivider": "boolean",
        "showFooterDivider": "boolean",
        "regionPaddingPreset": "compact | default | spacious",
        "closeButtonStyle": "ghost | subtle-circle | none",
        "subtitleTone": "neutral | dark | indigo",
        "subtitleClamp": "number | none",
        "footerNoteTone": "neutral | destructive | info | success",
        "footerNoteSingleLineWhenPossible": "boolean"
      }
    },
    "PopupLayout": {
      "path": "src/components/PopupLayout.tsx",
      "body_variants": [
        "body-only",
        "title-body",
        "label-body",
        "sectioned",
        "list",
        "banner-list",
        "form",
        "confirmation",
        "search-list",
        "hero-banner"
      ],
      "PopupHero": "Slot for onboarding/announcements"
    }
  },
  "anti_drift_rules": [
    "No arbitrary padding: use regionPaddingPreset",
    "No custom shell: use PopupRoot",
    "No manual divider lines: use showXDivider props",
    "Footer trays must use showFooterTray for parity background logic"
  ]
}
